<UserControl x:Class="DiffStream.VisualStudio.UI.DiffStreamToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="420">
  <Grid Background="#1E1E1E">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1" Padding="10">
      <StackPanel>
        <DockPanel LastChildFill="False">
          <Button Content="Pause" Width="70" Margin="0,0,6,0" Click="PauseClick" />
          <Button Content="Resume" Width="70" Margin="0,0,6,0" Click="ResumeClick" />
          <Button Content="Clear" Width="70" Margin="0,0,6,0" Click="ClearClick" />
          <Button Content="Start" Width="70" Margin="0,0,6,0" Click="StartClick" />
          <Button Content="Stop" Width="70" Click="StopClick" />
        </DockPanel>
        <TextBox x:Name="SearchBox"
                 Margin="0,10,0,0"
                 Height="26"
                 Padding="6,3"
                 Background="#252526"
                 Foreground="#F0F0F0"
                 BorderBrush="#3A3A3A"
                 TextChanged="SearchChanged"
                 ToolTip="Filter by file path" />
      </StackPanel>
    </Border>

    <ListBox x:Name="FeedList"
             Grid.Row="1"
             BorderThickness="0"
             Background="#1E1E1E"
             Foreground="#F0F0F0"
             ItemsSource="{Binding Events}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="8,6"
                  Padding="10"
                  BorderBrush="#3A3A3A"
                  BorderThickness="1"
                  CornerRadius="4"
                  Background="#181818">
            <StackPanel>
              <DockPanel>
                <TextBlock Text="{Binding TimeText}" Foreground="#B0B0B0" FontSize="11" Margin="0,0,8,0" />
                <TextBlock Text="{Binding Type}" Foreground="#4EC9B0" FontSize="11" FontWeight="Bold" />
              </DockPanel>
              <TextBlock Text="{Binding RelativePath}" FontWeight="Bold" Margin="0,8,0,3" TextWrapping="Wrap" />
              <TextBlock Text="{Binding Summary}" Foreground="#C8C8C8" TextWrapping="Wrap" />
              <ItemsControl ItemsSource="{Binding DisplayLines}" Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4" TextWrapping="NoWrap" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
